# ─────────────────────────────────────────────────────────
# FINPER API — Variables de entorno (plantilla)
# Copia este archivo como .env y rellena los valores reales.
# ─────────────────────────────────────────────────────────

NODE_ENV=development

# Base de datos — postgresql://<usuario>:<password>@<host>:<puerto>/<db>
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/finper_dev

# JWT — usa una cadena aleatoria larga en producción
JWT_SECRET=cambia_esto_en_produccion

# Puerto del servidor
PORT=3001
